<Window x:Class="Ming_AutoClicker.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="版本更新"
        Width="480"
        Height="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True">

    <!-- 主容器：圆角 + 阴影 -->
    <Border Background="{StaticResource SurfaceBrush}"
            CornerRadius="12"
            Margin="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.15" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>   <!-- 版本信息 -->
                <RowDefinition Height="*"/>      <!-- 更新说明 -->
                <RowDefinition Height="Auto"/>   <!-- 进度条 -->
                <RowDefinition Height="Auto"/>   <!-- 按钮 -->
            </Grid.RowDefinitions>

            <!-- 标题栏（可拖动，无关闭按钮 - 强制更新） -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryBrush}"
                    CornerRadius="12,12,0,0"
                    Padding="20,14"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔄 发现新版本"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="（需要更新后才能继续使用）"
                               FontSize="11"
                               Foreground="#CCFFFFFF"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- 版本信息 -->
            <Grid Grid.Row="1" Margin="20,16,20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 版本号 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4">
                        <Run Text="当前版本："/><Run x:Name="CurrentVersionRun" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="最新版本："/><Run x:Name="NewVersionRun" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                    </TextBlock>
                </StackPanel>

                <!-- 发布时间 -->
                <TextBlock Grid.Column="1"
                           x:Name="PublishDateText"
                           FontSize="11"
                           Foreground="{StaticResource TextDisabledBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- 分隔线 -->
            <Border Grid.Row="1"
                    VerticalAlignment="Bottom"
                    Height="1"
                    Background="{StaticResource BorderBrush}"
                    Margin="20,0"/>

            <!-- 更新说明（可滚动） -->
            <TextBox Grid.Row="2"
                     x:Name="ReleaseNotesText"
                     IsReadOnly="True"
                     Margin="20,12,20,8"
                     Padding="12"
                     FontSize="12"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Background="{StaticResource BackgroundBrush}"
                     BorderThickness="1"
                     BorderBrush="{StaticResource BorderBrush}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Cursor="Arrow"/>

            <!-- 下载进度区域 -->
            <Grid Grid.Row="3" x:Name="ProgressArea" Margin="20,4,20,12" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 进度条 -->
                <ProgressBar Grid.Row="0"
                             x:Name="DownloadProgress"
                             Height="6"
                             Minimum="0" Maximum="100"
                             Value="0"
                             Foreground="{StaticResource PrimaryBrush}"
                             Background="{StaticResource BorderLightBrush}"
                             BorderThickness="0"/>

                <!-- 进度信息 -->
                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="ProgressPercentText"
                               Text="0%"
                               FontSize="11"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontWeight="Medium"/>

                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Right"
                               x:Name="ProgressSizeText"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
            </Grid>

            <!-- 按钮区域（强制更新 - 只有"立即更新"按钮） -->
            <Border Grid.Row="4"
                    Background="{StaticResource StatusBarBrush}"
                    CornerRadius="0,0,12,12"
                    Padding="20,14"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}">
                <Button x:Name="UpdateButton"
                        Content="立即更新"
                        Style="{StaticResource PrimaryButton}"
                        Click="UpdateButton_Click"
                        FontSize="14"
                        FontWeight="Medium"
                        Padding="40,10"
                        HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>